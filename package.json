{
  "name": "mint-green-theme",
  "displayName": "Mint Green Theme",
  "description": "A mint green color theme with fully configurable colors and reset-to-default support.",
  "version": "0.1.0",
  "publisher": "panjie039",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caticat/mint-green-theme"
  },
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Themes"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Mint Green",
        "uiTheme": "vs",
        "path": "./themes/mint-green-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "mint-green-theme.resetColors",
        "title": "Mint Green Theme: Reset All Colors to Default"
      }
    ],
    "configuration": [
      {
        "title": "Editor Colors",
        "properties": {
          "mintGreenTheme.editor.background": {
            "type": "string",
            "default": "#CCE8CF",
            "description": "Editor background color"
          },
          "mintGreenTheme.editor.foreground": {
            "type": "string",
            "default": "#1E1E1E",
            "description": "Editor default text color"
          },
          "mintGreenTheme.editor.lineHighlightBackground": {
            "type": "string",
            "default": "#1100ff20",
            "description": "Editor current line highlight background"
          },
          "mintGreenTheme.editor.selectionBackground": {
            "type": "string",
            "default": "#ff212190",
            "description": "Editor selection background"
          },
          "mintGreenTheme.editor.selectionHighlightBackground": {
            "type": "string",
            "default": "#ff212150",
            "description": "Editor selection highlight background"
          },
          "mintGreenTheme.editor.findMatchBackground": {
            "type": "string",
            "default": "#fbff0071",
            "description": "Editor find match highlight background"
          },
          "mintGreenTheme.editor.findMatchHighlightBackground": {
            "type": "string",
            "default": "#00bfff69",
            "description": "Editor find all matches highlight background"
          },
          "mintGreenTheme.editor.findRangeHighlightBackground": {
            "type": "string",
            "default": "#ff99006e",
            "description": "Editor find range highlight background"
          },
          "mintGreenTheme.editorGutter.background": {
            "type": "string",
            "default": "#CCE8CF",
            "description": "Editor gutter (line number area) background"
          },
          "mintGreenTheme.editorLineNumber.foreground": {
            "type": "string",
            "default": "#2BA7BF",
            "description": "Editor line number foreground color"
          },
          "mintGreenTheme.editorWidget.background": {
            "type": "string",
            "default": "#E0F0E0",
            "description": "Editor widget background (autocomplete, hover docs, find widget)"
          },
          "mintGreenTheme.breadcrumb.background": {
            "type": "string",
            "default": "#CCE8CF",
            "description": "Breadcrumb navigation bar background"
          }
        }
      },
      {
        "title": "UI Colors",
        "properties": {
          "mintGreenTheme.titleBar.activeBackground": {
            "type": "string",
            "default": "#A8C8AB",
            "description": "Window title bar background"
          },
          "mintGreenTheme.activityBar.background": {
            "type": "string",
            "default": "#A8C8AB",
            "description": "Activity bar background (leftmost icon bar)"
          },
          "mintGreenTheme.activityBar.foreground": {
            "type": "string",
            "default": "#1A3A1A",
            "description": "Activity bar icon color (active)"
          },
          "mintGreenTheme.activityBarBadge.background": {
            "type": "string",
            "default": "#2E7D32",
            "description": "Activity bar badge background (e.g. git change count)"
          },
          "mintGreenTheme.statusBar.background": {
            "type": "string",
            "default": "#7AAD7E",
            "description": "Status bar background (bottom bar)"
          },
          "mintGreenTheme.statusBar.foreground": {
            "type": "string",
            "default": "#F0FFF0",
            "description": "Status bar foreground text color"
          },
          "mintGreenTheme.editorGroupHeader.tabsBackground": {
            "type": "string",
            "default": "#c1d3c1",
            "description": "Tab bar background color"
          },
          "mintGreenTheme.tab.activeBackground": {
            "type": "string",
            "default": "#CCE8CF",
            "description": "Active tab background color"
          },
          "mintGreenTheme.tab.inactiveBackground": {
            "type": "string",
            "default": "#b1cab1",
            "description": "Inactive tab background color"
          },
          "mintGreenTheme.tab.hoverBackground": {
            "type": "string",
            "default": "#C4DFC4",
            "description": "Tab hover background color"
          },
          "mintGreenTheme.tab.activeBorder": {
            "type": "string",
            "default": "#5A9A5A",
            "description": "Active tab bottom border highlight"
          },
          "mintGreenTheme.sideBar.background": {
            "type": "string",
            "default": "#BCD8BF",
            "description": "Sidebar background color"
          },
          "mintGreenTheme.sideBar.foreground": {
            "type": "string",
            "default": "#1A3A1A",
            "description": "Sidebar foreground text color"
          },
          "mintGreenTheme.sideBarSectionHeader.background": {
            "type": "string",
            "default": "#A8C8AB",
            "description": "Sidebar section header background (EXPLORER, GIT, etc.)"
          },
          "mintGreenTheme.panel.background": {
            "type": "string",
            "default": "#D0F0D0",
            "description": "Panel (terminal area) background color"
          },
          "mintGreenTheme.terminal.background": {
            "type": "string",
            "default": "#D0F0D0",
            "description": "Integrated terminal background color"
          },
          "mintGreenTheme.focusBorder": {
            "type": "string",
            "default": "#5A9A5A",
            "description": "Global focus border color (input focus outline, etc.)"
          },
          "mintGreenTheme.input.background": {
            "type": "string",
            "default": "#E8F5E9",
            "description": "Input box background (search, replace, find bar, etc.)"
          },
          "mintGreenTheme.dropdown.background": {
            "type": "string",
            "default": "#E8F5E9",
            "description": "Dropdown / combobox background (terminal profile selector, etc.)"
          },
          "mintGreenTheme.list.hoverBackground": {
            "type": "string",
            "default": "#B8DDB8",
            "description": "List / file tree item hover background"
          },
          "mintGreenTheme.list.activeSelectionBackground": {
            "type": "string",
            "default": "#A0CCA0",
            "description": "List / file tree active selection background"
          },
          "mintGreenTheme.list.inactiveSelectionBackground": {
            "type": "string",
            "default": "#AACFAA",
            "description": "List / file tree inactive selection background"
          },
          "mintGreenTheme.scrollbarSlider.background": {
            "type": "string",
            "default": "#A8C8AB80",
            "description": "Scrollbar slider background"
          },
          "mintGreenTheme.scrollbarSlider.hoverBackground": {
            "type": "string",
            "default": "#7AAD7EAA",
            "description": "Scrollbar slider hover background"
          }
        }
      },
      {
        "title": "Syntax Token Colors",
        "properties": {
          "mintGreenTheme.token.comment": {
            "type": "string",
            "default": "#6A9955",
            "description": "Token color: comments"
          },
          "mintGreenTheme.token.string": {
            "type": "string",
            "default": "#A31515",
            "description": "Token color: strings"
          },
          "mintGreenTheme.token.keyword": {
            "type": "string",
            "default": "#0000FF",
            "description": "Token color: keywords"
          },
          "mintGreenTheme.token.number": {
            "type": "string",
            "default": "#098658",
            "description": "Token color: numbers"
          },
          "mintGreenTheme.token.function": {
            "type": "string",
            "default": "#795E26",
            "description": "Token color: function names"
          },
          "mintGreenTheme.token.type": {
            "type": "string",
            "default": "#267F99",
            "description": "Token color: types and classes"
          },
          "mintGreenTheme.token.variable": {
            "type": "string",
            "default": "#001080",
            "description": "Token color: variables"
          },
          "mintGreenTheme.token.parameter": {
            "type": "string",
            "default": "#383838",
            "description": "Token color: function parameters"
          }
        }
      },
      {
        "title": "Advanced: Editor",
        "properties": {
          "mintGreenTheme.editor.wordHighlightBackground": {
            "type": "string",
            "default": "#B0D4FF80",
            "description": "Word highlight background when cursor is on a symbol (read access)"
          },
          "mintGreenTheme.editor.wordHighlightStrongBackground": {
            "type": "string",
            "default": "#FFD70080",
            "description": "Word highlight background for write access positions"
          },
          "mintGreenTheme.editorBracketMatch.background": {
            "type": "string",
            "default": "#A8D8A850",
            "description": "Matching bracket highlight background"
          },
          "mintGreenTheme.editorBracketMatch.border": {
            "type": "string",
            "default": "#5A9A5A",
            "description": "Matching bracket highlight border"
          },
          "mintGreenTheme.editorCursor.foreground": {
            "type": "string",
            "default": "#2E7D32",
            "description": "Editor cursor color"
          },
          "mintGreenTheme.editorIndentGuide.background1": {
            "type": "string",
            "default": "#B0D0B080",
            "description": "Editor indent guide line color"
          },
          "mintGreenTheme.editorRuler.foreground": {
            "type": "string",
            "default": "#A0C0A060",
            "description": "Editor ruler line color (80/120 col guides)"
          },
          "mintGreenTheme.editorWhitespace.foreground": {
            "type": "string",
            "default": "#B0D0B0",
            "description": "Whitespace character color (spaces, tabs when visible)"
          }
        }
      },
      {
        "title": "Advanced: UI Elements",
        "properties": {
          "mintGreenTheme.tab.unfocusedActiveBackground": {
            "type": "string",
            "default": "#C0DCC0",
            "description": "Active tab background when window is unfocused"
          },
          "mintGreenTheme.input.border": {
            "type": "string",
            "default": "#A8C8AB",
            "description": "Input box border color"
          },
          "mintGreenTheme.activityBar.inactiveForeground": {
            "type": "string",
            "default": "#4A7A4A",
            "description": "Activity bar icon color (inactive)"
          },
          "mintGreenTheme.titleBar.activeForeground": {
            "type": "string",
            "default": "#1A3A1A",
            "description": "Title bar foreground text color"
          },
          "mintGreenTheme.titleBar.inactiveBackground": {
            "type": "string",
            "default": "#B8D4BB",
            "description": "Title bar background when window is unfocused"
          },
          "mintGreenTheme.sideBarSectionHeader.foreground": {
            "type": "string",
            "default": "#1A3A1A",
            "description": "Sidebar section header foreground text color"
          },
          "mintGreenTheme.statusBar.debuggingBackground": {
            "type": "string",
            "default": "#5A8A5A",
            "description": "Status bar background while debugging"
          },
          "mintGreenTheme.statusBar.noFolderBackground": {
            "type": "string",
            "default": "#8AB88E",
            "description": "Status bar background when no folder is open"
          },
          "mintGreenTheme.button.background": {
            "type": "string",
            "default": "#5A9A5A",
            "description": "Primary button background color"
          },
          "mintGreenTheme.badge.background": {
            "type": "string",
            "default": "#2E7D32",
            "description": "Badge background (extension count, etc.)"
          },
          "mintGreenTheme.notifications.background": {
            "type": "string",
            "default": "#E0F0E0",
            "description": "Notification popup background (bottom-right)"
          }
        }
      },
      {
        "title": "Advanced: Git Decorations",
        "properties": {
          "mintGreenTheme.gitDecoration.modifiedResourceForeground": {
            "type": "string",
            "default": "#E65100",
            "description": "File tree color for modified files"
          },
          "mintGreenTheme.gitDecoration.untrackedResourceForeground": {
            "type": "string",
            "default": "#1565C0",
            "description": "File tree color for untracked files"
          },
          "mintGreenTheme.gitDecoration.deletedResourceForeground": {
            "type": "string",
            "default": "#B71C1C",
            "description": "File tree color for deleted files"
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.2"
  }
}
